{
  "name": "AI-Powered Lead Generation and Qualification with Auto-Scheduling",
  "nodes": [
    {
      "parameters": {
        "formTitle": "Get in Touch - Let's Discuss Your Needs",
        "formDescription": "Fill out this form and we'll get back to you shortly",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Full Name",
              "requiredField": true
            },
            {
              "fieldLabel": "Email Address",
              "fieldType": "email",
              "requiredField": true
            },
            {
              "fieldLabel": "Company Name",
              "requiredField": true
            },
            {
              "fieldLabel": "Company Size",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "1-10 employees"
                  },
                  {
                    "option": "11-50 employees"
                  },
                  {
                    "option": "51-200 employees"
                  },
                  {
                    "option": "201-500 employees"
                  },
                  {
                    "option": "500+ employees"
                  }
                ]
              }
            },
            {
              "fieldLabel": "What challenges are you facing?",
              "fieldType": "textarea",
              "requiredField": true
            },
            {
              "fieldLabel": "Budget Range",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Under $5,000"
                  },
                  {
                    "option": "$5,000 - $15,000"
                  },
                  {
                    "option": "$15,000 - $50,000"
                  },
                  {
                    "option": "$50,000+"
                  },
                  {
                    "option": "Not sure yet"
                  }
                ]
              }
            },
            {
              "fieldLabel": "Timeline",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Urgent (within 1 month)"
                  },
                  {
                    "option": "Soon (1-3 months)"
                  },
                  {
                    "option": "Planning (3-6 months)"
                  },
                  {
                    "option": "Exploring options"
                  }
                ]
              }
            }
          ]
        },
        "options": {
          "appendAttribution": false,
          "buttonLabel": "Submit",
          "respondWithOptions": {
            "values": {
              "formSubmittedText": "Thank you! We've received your information and will be in touch soon."
            }
          }
        }
      },
      "id": "bcc045f6-918e-471d-8723-5516f70c3691",
      "name": "Lead Generation Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.3,
      "position": [
        1376,
