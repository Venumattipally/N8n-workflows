      ],
      "webhookId": "5b27963d-0164-4988-a601-e754cd4dceb1",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "id-1",
              "name": "highScoreThreshold",
              "value": 7,
              "type": "number"
            },
            {
              "id": "id-2",
              "name": "calendarLookAheadDays",
              "value": 14,
              "type": "number"
            },
            {
              "id": "id-3",
              "name": "meetingDurationMinutes",
              "value": 15,
              "type": "number"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "00d10006-9519-4884-8d00-7afddd6d2212",
      "name": "Workflow Configuration",
